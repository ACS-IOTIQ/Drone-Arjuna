# Copy this file to .env and fill in values before running docker-compose

# ── PostgreSQL ──────────────────────────────────────────────────────
POSTGRES_DB=dronearjuna
POSTGRES_USER=da_admin
POSTGRES_PASSWORD=changeme

# ── TimescaleDB ─────────────────────────────────────────────────────
TIMESCALE_DB=da_telemetry

# pgAdmin web database UI
PGADMIN_DEFAULT_EMAIL=admin@dronearjuna.local
PGADMIN_DEFAULT_PASSWORD=changeme

# ── Redis ───────────────────────────────────────────────────────────
REDIS_PASSWORD=changeme

# ── RabbitMQ ────────────────────────────────────────────────────────
RABBITMQ_USER=da_mq
RABBITMQ_PASSWORD=changeme

# ── MinIO ───────────────────────────────────────────────────────────
MINIO_USER=da_minio
MINIO_PASSWORD=changeme123

# ── App secrets ─────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=please-change-this-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ─────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── MAVLink SITL (for development without a real drone) ──────────────
SITL_HOST=host.docker.internal
SITL_PORT=14550
